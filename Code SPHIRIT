    def measure_surface_elevation(pos, types, rho, rho0, x_probe, h_sph):
        """
        √Čl√©vation de surface √† la sonde x_probe.
        M√©thode : interpolation Shepard de ŌĀ sur la colonne, puis d√©tection
        du niveau ŌĀ = ŌĀ0/2 (interface eau/air SPH).
        Fallback : position de la plus haute particule fluide dans |x-x_p| < h.
        """
        mask_f = (types == FLUID)
        band   = mask_f & (np.abs(pos[:, 0] - x_probe) < h_sph)

        if not np.any(band):
            return 0.0

        # M√©thode rapide : plus haute particule dans la bande
        y_top = np.max(pos[band, 1])
        return y_top - H_water


