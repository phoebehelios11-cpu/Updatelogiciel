def update_neighborhood(new_pos, h):
    # On reconstruit l'arbre avec les positions actuelles
    new_tree = cKDTree(new_pos)
    # On cherche les paires de particules √† une distance d'influence (souvent 2h ou 3h)
    new_pairs = new_tree.query_pairs(r=2.0 * h) # Adapte le rayon selon ton noyau
    return new_tree, new_pairs
def kernel_cubic(r, h):
    q = r / h
    sigma = 10.0 / (7.0 * np.pi * h**2)
    return np.where(q <= 1.0, sigma * (1 - 1.5*q**2 + 0.75*q**3), 
           np.where(q <= 2.0, sigma * 0.25 * (2 - q)**3, 0.0))

def kernel_grad(rij, r, h):
    q = r / h
    sigma_g = 10.0 / (7.0 * np.pi * h**3)
    dw_r = np.where(q <= 1.0, sigma_g * (-3.0*q + 2.25*q**2),
           np.where(q <= 2.0, -sigma_g * 0.75 * (2.0 - q)**2, 0.0))
    return (dw_r / (r + 1e-12)) * rij, dw_r

# √Ä d√©finir dans vos param√®tres globaux (ex: √©gale √† la pression hydrostatique max)
# P_b = rho0 * g_acc * H_water 
P_b = 0.01 * B # Une fraction de B fonctionne souvent tr√®s bien en WCSPH

def get_pressure(rho):
    # L'√©quation de Tait avec la pression de fond
    p_tait = B * (np.power(rho / rho0, gamma) - 1.0)
    
    # On garantit que la pression totale absolue reste positive
    p_total = p_tait + P_b
    
    return np.maximum(p_total, 0.0) 

def get_density(p):
    # Il faut soustraire la pression de fond pour retrouver la composante Tait pure
    # avant d'inverser l'√©quation
    p_dynamic = p - P_b
    p_clamped = np.clip(p_dynamic, -0.9*B, 5.0*rho0*c0**2)
    
    return rho0 * np.power(np.maximum((p_clamped / B) + 1.0, 1e-6), 1.0 / gamma)

def minmod_vec(a, b):
    # Version vectoris√©e pour Numpy
    res = np.zeros_like(a)
    mask = a * b > 0
    res[mask] = np.sign(a[mask]) * np.minimum(np.abs(a[mask]), np.abs(b[mask]))
    return res

def minmod(a, b):
    if a*b <= 0:
        return 0
    else:
        return np.sign(a) * min(abs(a), abs(b))   
        
def van_albada(a, b):
    """Forme sym√©trique : prend deux pentes a et b et renvoie la pente limit√©e."""
    eps = 1e-12
    #if a * b <= 0.0:
       # return 0.0  # Signes oppos√©s = extremum local = ordre 1 (pente nulle)
    return 1.0#(a * (b**2 + eps) + b * (a**2 + eps)) / (a**2 + b**2 + 2.0 * eps)
    
def riemann_solver(rhoL, uL, pL, rhoR, uR, pR, c0, P_b):
    #Solveur Rusanov / Local Lax‚ÄďFriedrichs lin√©aris√© (forme acoustique)
    rho_avg = 0.5 * (rhoL + rhoR)
    #if rho_avg < 1e-6: return 0.5 * (uL + uR), 0.5 * (pL + pR)
    beta = 0.5 
    pL_dyn, pR_dyn = pL - P_b, pR - P_b
    p_star_dyn = 0.5*(pL_dyn + pR_dyn) - beta * rho_avg * c0 * (uR - uL)
    u_star = 0.5*(uL + uR)         - beta * (pR_dyn - pL_dyn) / (rho_avg*c0 + 1e-12)    
    # On rajoute P_b pour renvoyer une pression TOTALE absolue
    p_star = p_star_dyn + P_b 
    return u_star, p_star

def get_tgv_solution(pos, t, L, U0, nu):
    k = 2 * np.pi / L
    decay = np.exp(-2 * k**2 * nu * t)
    u =  U0 * np.sin(k*pos[:,0]) * np.cos(k*pos[:,1]) * decay
    v = -U0 * np.cos(k*pos[:,0]) * np.sin(k*pos[:,1]) * decay
    p = (rho0 * U0**2 / 4.0) * (np.cos(2*k*pos[:,0]) + np.cos(2*k*pos[:,1])) * decay**2
    return np.column_stack((u, v)), p
