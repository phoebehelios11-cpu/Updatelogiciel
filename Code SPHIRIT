        v_mesh, F1, FS, F2, grad_W2, grad_FS, lloyd_shift = compute_v_mesh_coupled(pos, vel_f, vol_f, h, dt, shepard, tree, pairs,
                           alpha, beta_geom, mode_ale)        
        
