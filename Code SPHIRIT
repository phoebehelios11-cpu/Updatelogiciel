def compute_renormalization_matrices_robust(pairs, pos, vol, h, shepard_coeff, L_matrices):
    """
    Calcule Li avec r√©gularisation pour les particules en surface libre
    ou avec un support pauvre.
    """
    num_particles = pos.shape[0]
    M = np.zeros((num_particles, 2, 2))
    cond_array = np.ones(num_particles)
    renorm_status = np.zeros(num_particles, dtype=int) # 0 par d√©faut
    I2 = np.eye(2)
    
    # 1. Accumulation de la matrice M (Identique √† pr√©c√©demment)
    for i, j in pairs:
        rij = periodic_rij(pos[i], pos[j]) if Periodic else pos[i] - pos[j]
        r = np.linalg.norm(rij)
        if r < 1e-12 or r > 2.0 * h: continue

        g_w, _ = kernel_grad(rij, r, h)
        
        M[i] += vol[j] * np.outer(-rij, g_w)
        M[j] += vol[i] * np.outer(rij, -g_w)

    # 2. Inversion avec vigilance (Surface Libre & Conditionnement)
    for i in range(num_particles):
        # On utilise le coefficient de Shepard pour d√©tecter le manque de voisins
        # Une particule compl√®te a shepard_coeff ~ 1.0
        s_i = shepard_coeff[i]
        
        det = np.linalg.det(M[i])
        cond_number = 0.0        

        # CRIT√ąRES DE VIGILANCE :
        # - D√©terminant trop petit
        # - Nombre de conditionnement trop grand (> 100)
        # - Coefficient de Shepard trop faible (particule isol√©e < 0.2)   
        if abs(det) > 1e-15:
            norm_M = np.linalg.norm(M[i])
            norm_invM = np.linalg.norm(np.linalg.inv(M[i]))
            cond_i = norm_M * norm_invM
            cond_array[i] = cond_i 
        else:
            cond_array[i] = 1e6 # Valeur arbitraire haute pour signaler une singularit√©    
         # Choix de la branche
        if s_i < 0.2 or abs(det) < 1e-7 or cond_array[i] > 100.0:
            epsilon = max(0, 0.5 - s_i)
            L_matrices[i] = np.linalg.inv(M[i] + epsilon * np.eye(2))
            renorm_status[i] = 1 # R√©gularis√©
        else:
            L_matrices[i] = np.linalg.inv(M[i])
            renorm_status[i] = 2 # Full Renorm
            
    return cond_array, renorm_status   
            
def add_periodic_ghosts(pos, types, h, L):
    """Ajoute des copies fant√īmes pour compl√©ter le support aux bords"""
    idx_boundary = (pos[:, 0] < h) | (pos[:, 0] > L - h)
    
    if not np.any(idx_boundary):
        return pos, types
    
    # Copies en (-L, y) et (L, y)
    pos_left = pos[idx_boundary].copy()
    pos_left[:, 0] -= L
    
    pos_right = pos[idx_boundary].copy()
    pos_right[:, 0] += L
    
    pos_extended = np.vstack([pos, pos_left, pos_right])
    types_extended = np.concatenate([types, types[idx_boundary], types[idx_boundary]])
    
    return pos_extended, types_extended            
            
