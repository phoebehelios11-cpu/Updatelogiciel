def fill_circle(cx, cy, radius):

    pts = []

    xs = np.arange(cx-radius, cx+radius, dx)
    ys = np.arange(cy-radius, cy+radius, dx)

    for x in xs:
        for y in ys:
            if (x-cx)**2 + (y-cy)**2 <= radius**2 :
                pts.append([x, y])

    return pts


