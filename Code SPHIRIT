    def test_renormalization_order():

        resolutions = [20, 40, 80]
        errors_const = []
        errors_lin = []
        errors_quad = []
        dx = []
        for N in resolutions:
            pos, vol, h, _ = generate_particles(N)
            dx.append(1/N)
            num_particles = len(pos)
            # 1. Construction des paires et calcul de L
            tree = cKDTree(pos)
            pairs = list(tree.query_pairs(2*h))
            shepard = np.ones(num_particles)
            L = np.zeros((num_particles, 2, 2))
            cond, status = compute_renormalization_matrices_robust(
                pairs, pos, vol, h, shepard, L)
            # =======================================================
            # FONCTION INTERNE : Calcul du gradient SPH brut (Non corrig√©)
            # =======================================================
            def compute_raw_sph_gradient(field):
                grad_sph = np.zeros((num_particles, 2))
                for i, j in pairs:
                    rij = pos[i] - pos[j] # Attention au signe selon votre kernel_grad
                    r = np.linalg.norm(rij)
                    if r < 1e-12 or r > 2.0 * h: continue
                    
                    # Calcul du gradient du noyau
                    g_w, _ = kernel_grad(rij, r, h)
                    
                    # Formule SPH classique du gradient : 
                    # grad(f)_i = Somme_j ( V_j * (f_j - f_i) * gradW_ij )
                    # Note : Ajustez le signe de (f_j - f_i) ou g_w selon vos conventions habituelles
                    grad_sph[i] += vol[j] * (field[j] - field[i]) * g_w
                    grad_sph[j] += vol[i] * (field[i] - field[j]) * (-g_w)
                return grad_sph
    
            # =======================================================
            # Reconstruction & Correction par la matrice L
            # =======================================================
    
            # ---- Constant ----
            f = field_constant(pos)
            grad_raw = compute_raw_sph_gradient(f)
            grad_corrected = np.einsum("nij,nj->ni", L, grad_raw)
            errors_const.append(np.linalg.norm(grad_corrected))
    
            # ---- Linear ----
            f = field_linear(pos)
            grad_exact = grad_linear_exact(pos)
            
            grad_raw = compute_raw_sph_gradient(f)
            # Application de la correction : grad_corrected = L @ grad_raw
            grad_corrected = np.einsum("nij,nj->ni", L, grad_raw)
            
            errors_lin.append(L2_error_interior(grad_corrected, grad_exact, pos))
    
            # ---- Quadratic ----
            f = field_quadratic(pos)
            grad_exact = grad_quadratic_exact(pos)
            
            grad_raw = compute_raw_sph_gradient(f)
            grad_corrected = np.einsum("nij,nj->ni", L, grad_raw)
            
            errors_quad.append(L2_error_interior(grad_corrected, grad_exact, pos))
    
        dx = np.array(dx)
    
        order_lin = np.polyfit(np.log(dx), np.log(errors_lin), 1)[0]
        order_quad = np.polyfit(np.log(dx), np.log(errors_quad), 1)[0]
    
        print("--- R√©sultats Renormalisation Corrig√©s ---")
        print("Valeurs brutes errors_lin :", errors_lin)
        print("Valeurs brutes errors_quad :", errors_quad)
        print("Renorm linear order:", order_lin)
        print("Renorm quadratic order:", order_quad)
    
    
    
