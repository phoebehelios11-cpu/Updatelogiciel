            exact=grad_linear_exact(pos)
            errors_lin.append(L2_error_interior(grad,exact, pos))

            # ---- quadratic ----
            f=field_quadratic(pos)
            grad=compute_mls_gradients(pos,vol,f,h,tree,p_ref,cond_MLS)
            exact=grad_quadratic_exact(pos)
