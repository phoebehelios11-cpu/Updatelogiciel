def fill_polygon(polygon):

    polygon = np.array(polygon)

    xmin, ymin = polygon.min(axis=0)
    xmax, ymax = polygon.max(axis=0)

    pts = []

    xs = np.arange(xmin, xmax, dx)
    ys = np.arange(ymin, ymax, dx)

    for x in xs:
        for y in ys:
            if point_in_polygon(x, y, polygon):
                pts.append([x, y])

    return pts


